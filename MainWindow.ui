        </item>
        <item>
         <layout class="QVBoxLayout" name="rightLayout" stretch="0,0,1">
          <item>
           <widget class="QPushButton" name="calcBtn" minimumSize="0,50">
            <property name="styleSheet">
             <string>font-size:18px; font-weight:bold; background-color:rgb(0,170,0); color:white;</string>
            </property>
            <property name="text">
             <string>一键计算最优出牌顺序</string>
            </property>
           </widget>
          </item>
          <item>
           <layout class="QVBoxLayout" name="resultInfoLayout">
            <item>
             <widget class="QLabel" name="maxProfitLabel">
