              <widget class="QLabel" name="previewLabel" minimumSize="400,200">
               <property name="alignment">
                <set>Qt::AlignCenter</set>
               </property>
               <property name="text">
                <string>预览画面</string>
               </property>
               <property name="frameShape">
                <enum>QFrame::Box</enum>
               </property>
              </widget>
             </item>
            </layout>
           </widget>
          </item>
